# Groq API — free tier at https://console.groq.com
GROQ_API_KEY=gsk_...
GROQ_MODEL=llama-3.1-8b-instant   # options: llama-3.3-70b-versatile, gemma2-9b-it, mixtral-8x7b-32768

# Voyage AI — free tier at https://dash.voyageai.com
# (200M lifetime tokens for voyage-3*; 10K TPM / 3 RPM until payment method added)
VOYAGE_API_KEY=pa-...

# Voyage rate-limit throttling (optional). Defaults match the no-payment
# free tier. Bump these once a payment method is on file to use the
# standard limits (e.g. 1,000,000 TPM / 2,000 RPM).
# VOYAGE_TPM_LIMIT=10000
# VOYAGE_RPM_LIMIT=3
# VOYAGE_TPM_SAFETY=0.9     # use 90% of TPM as headroom
# VOYAGE_MAX_RETRIES=5      # retries on RateLimitError with backoff

# Retrieval tuning (optional)
# TOP_K_RETRIEVAL=10
# TOP_K_RERANK=5
