# ── Groq (Cloud, free tier) ───────────────────────────────────────────────────
# Get a free API key at https://console.groq.com
# GROQ_API_KEY=gsk_...
# GROQ_MODEL=llama-3.1-8b-instant   # options: llama-3.3-70b-versatile, gemma2-9b-it, mixtral-8x7b-32768

# ── Local LLM via Ollama ──────────────────────────────────────────────────────
# 1. Install Ollama:  https://ollama.com
# 2. Pull a model:    `ollama pull qwen2.5:3b`   (or qwen2.5:7b, llama3.1:8b, ...)
# 3. Start the daemon: launch the Ollama app, or run `ollama serve`
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=qwen2.5:3b

# Retrieval tuning (optional)
# TOP_K_RETRIEVAL=10
# TOP_K_RERANK=5
